        -                                         conflict = true
        -                                         break
        -                                     end
        -                                 end
        -                             end
        - 
        -                             if !conflict
        -                                 push!(points_to_insert, (global_point_idx, global_face_id))
        -                                 union!(to_remove_faces, visible_faces)
