      144     gpu_pts = KernelAbstractions.zeros(backend, Float64, (size(points, 1), n_points))
        0     copyto!(gpu_pts, points)
        - 
        0     return _quick_hull_implem(context, segment_mem_data_float, segment_mem_data_int, gpu_pts)
