        - 
        - function read_input_file(path)
        -     f = open(path)
        -     data = split(strip(readline(f)), " ")
        -     
        -     local dim, pt_cnt
        -     if data[2] == "rbox"
        -         dim = parse(Int, data[1])
        -         pt_cnt = parse(Int, strip(readline(f)))
        -     else
        -         pt_cnt, dim = map((x) -> parse(Int, x), split(strip(readline(f)), " "))
        -     end
        - 
        -     points = zeros(Float64, dim, pt_cnt)
        -     for line in range(1, pt_cnt)
        -         points[:, line] =  map((x) -> parse(Float64, x), split(strip(readline(f)), " "))
        -     end
        -     close(f)
        - 
        -     return points
        - end
        - 
        - function sort_points_counter_clockwise(points)
        0     points = Array(points)
      672     barycenter = sum(points, dims=2)[:] ./ size(points, 2)
   211416     angles = atan.(points[2, :] .- barycenter[2], points[1, :] .- barycenter[1])
   155960     sorted_indices = sortperm(angles)
   280872     return points[:, sorted_indices]
        - end
